{
  "name": "@piloto/api",
  "version": "0.1.0",
  "private": true,
  "description": "API HTTP del piloto (reservas públicas y recepción); scaffold mínimo según openspec/changes/piloto-reservas-recepcion/design.md",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "node --watch --import tsx src/main.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --import tsx src/infrastructure/persistence/migrate.ts",
    "db:seed": "node --import tsx src/infrastructure/persistence/seed-cli.ts"
  },
  "dependencies": {
    "@piloto/shared-types": "*",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.14.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
